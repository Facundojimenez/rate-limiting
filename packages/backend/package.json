{
  "name": "@rate-limiter-monorepo/backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "test": "jest --config jest.config.js --coverage"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/_test_"],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    },
    "collectCoverageFrom": [
      "src/controllers/**/*.ts",
      "src/services/**/*.ts",
      "src/middleware/**/*.ts",
      "src/utils/**/*.ts",
      "src/routes/**/*.ts",
      "src/app.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 90
      }
    }
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "log4js": "^6.9.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "jest": "^30.4.2"
  }
}
