FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package.json tsconfig.json ./

# Copy source code
COPY src ./src

# Install dependencies with verbose output to detect missing packages
RUN npm install --verbose || (echo "Failed to install dependencies" && exit 1)

# Add healthcheck script
RUN echo '#!/bin/sh' > /healthcheck.sh && \
    echo 'wget --spider -q http://localhost:3000 || exit 1' >> /healthcheck.sh && \
    chmod +x /healthcheck.sh

EXPOSE 3000

HEALTHCHECK --interval=10s --timeout=5s --retries=5 CMD /healthcheck.sh

CMD ["npm", "run", "dev:watch"]
